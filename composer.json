{
    "name": "mobility-work/zendesk-refactor",
    "description": "ZendeskService refactoring — Hexagonal Architecture, DDD, CQRS, AI enrichment",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0",
        "symfony/http-client": "^6.0|^7.0",
        "zendesk/zendesk_api_client_php": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpro/grumphp": "^2.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MobilityWork\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MobilityWork\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "phpro/grumphp": true
        }
    },
    "scripts": {
        "test":    "./vendor/bin/phpunit --testdox --testsuite Unit",
        "analyse": "./vendor/bin/phpstan analyse --no-progress",
        "cs-fix":  "./vendor/bin/php-cs-fixer fix",
        "cs-check":"./vendor/bin/php-cs-fixer fix --dry-run --diff",
        "qa":      ["@cs-check", "@analyse", "@test"]
    },
    "extra": {
        "grumphp": {
            "config-default-path": "grumphp.yml"
        }
    }
}

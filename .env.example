# =============================================================================
# Zendesk credentials — NEVER commit real values
# =============================================================================
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_USERNAME=agent@yourcompany.com
ZENDESK_TOKEN=your_api_token

# =============================================================================
# AI Ticket Enrichment (optional)
# =============================================================================
# Master switch. Set to false to disable all AI enrichment (safe default).
AI_ENABLED=false

# Provider: anthropic | ollama
# Add your own by implementing LlmClientInterface + one case in TicketEnricherFactory
AI_PROVIDER=anthropic

# --- Anthropic (Claude) ---
# Required when AI_PROVIDER=anthropic
AI_ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — defaults to claude-sonnet-4-20250514
AI_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Ollama (local, no key required) ---
# Required when AI_PROVIDER=ollama + Ollama running locally (https://ollama.com)
AI_OLLAMA_BASE_URL=http://localhost:11434
AI_OLLAMA_MODEL=llama3

# --- Shared ---
AI_MAX_TOKENS=256
